{
  "name": "skill-manager",
  "version": "1.3.4",
  "description": "管理和推送你的 Skills 到各个工具",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "mcp:provider-registry": "node mcp/provider_registry_mcp.js",
    "mcp:provider-registry:smoke": "node mcp/provider_registry_mcp_smoke.js",
    "mcp:install-provider-registry:mvp": "node scripts/mcp/install_provider_registry_mvp.js",
    "clean:release": "node scripts/release/cleanReleaseDir.js",
    "build": "vite build",
    "dist": "npm run dist:mac",
    "dist:mac": "npm run clean:release && npm run build && electron-builder --mac --arm64",
    "dist:win": "npm run clean:release && npm run build && electron-builder --win nsis --x64",
    "preview": "vite preview",
    "test": "npm run test:v04 && npm run test:v05",
    "test:v04": "vitest run --config 自动化测试/V0.4/vitest.config.js",
    "test:v04:watch": "vitest --config 自动化测试/V0.4/vitest.config.js",
    "test:v05": "vitest run --config 自动化测试/V0.5/vitest.config.js",
    "test:v05:watch": "vitest --config 自动化测试/V0.5/vitest.config.js",
    "test:v06": "vitest run --config 自动化测试/V0.6/vitest.config.js",
    "test:v06:watch": "vitest --config 自动化测试/V0.6/vitest.config.js",
    "test:v07": "vitest run --config 自动化测试/V0.7/vitest.config.js",
    "test:v07:watch": "vitest --config 自动化测试/V0.7/vitest.config.js",
    "test:v08": "vitest run --config 自动化测试/V0.8/vitest.config.js",
    "test:v08:watch": "vitest --config 自动化测试/V0.8/vitest.config.js",
    "test:v09": "npm run test:v09:backend && npm run test:v09:integration",
    "test:v09:backend": "vitest run --config 自动化测试/V0.9/vitest.backend.config.js",
    "test:v09:integration": "vitest run --config 自动化测试/V0.9/vitest.integration.config.js",
    "test:v09:watch": "vitest --config 自动化测试/V0.9/vitest.integration.config.js",
    "test:v12": "npm run test:v12:backend && npm run test:v12:integration",
    "test:v12:backend": "vitest run --config 自动化测试/V0.12/vitest.backend.config.js",
    "test:v12:integration": "vitest run --config 自动化测试/V0.12/vitest.integration.config.js",
    "test:v12:watch": "vitest --config 自动化测试/V0.12/vitest.integration.config.js",
    "test:v16": "npm run test:v16:backend && npm run test:v16:integration",
    "test:v16:backend": "vitest run --config 自动化测试/V0.16/vitest.backend.config.js",
    "test:v16:integration": "vitest run --config 自动化测试/V0.16/vitest.integration.config.js",
    "test:v16:watch": "vitest --config 自动化测试/V0.16/vitest.integration.config.js",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:report": "npm run test:coverage && node tests/generate-report.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:v04": "npm run build && playwright test --config 自动化测试/V0.4/playwright.config.js",
    "test:e2e:v05": "npm run build && playwright test --config 自动化测试/V0.5/playwright.config.js",
    "test:e2e:v06": "npm run build && playwright test --config 自动化测试/V0.6/playwright.config.js",
    "test:e2e:v07": "npm run build && playwright test --config 自动化测试/V0.7/playwright.config.js",
    "test:e2e:v09": "npm run build && playwright test --config 自动化测试/V0.9/playwright.config.js",
    "test:e2e:v12": "npm run build && playwright test --config 自动化测试/V0.12/playwright.config.js",
    "test:e2e:v16": "npm run build && playwright test --config 自动化测试/V0.16/playwright.config.js",
    "test:v04:all": "npm run test:v04 && npm run test:e2e:v04",
    "test:regression:all": "npm run test:v04:all && npm run test:v05:all",
    "test:v05:all": "npm run test:v05 && npm run test:e2e:v05",
    "test:v06:all": "npm run test:v06 && npm run test:e2e:v06",
    "test:v07:all": "npm run test:v07 && npm run test:e2e:v07",
    "test:v09:all": "npm run test:v09 && npm run test:e2e:v09",
    "test:v12:all": "npm run test:v12 && npm run test:e2e:v12",
    "test:v16:all": "npm run test:v16 && npm run test:e2e:v16"
  },
  "keywords": [
    "electron",
    "react",
    "skill-manager"
  ],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.skillmanager.app",
    "productName": "CodePal",
    "mac": {
      "icon": "assets/app-icons/icon.icns",
      "target": {
        "target": "dmg",
        "arch": [
          "arm64"
        ]
      },
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "icon": "assets/app-icons/icon.ico",
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "templates/**/*",
      "mcp/**/*",
      "!**/*.map",
      "!**/.provider-manifests.json",
      "!**/.provider-manifests.json.bak.*",
      "!.provider-manifests.json",
      "!.provider-manifests.json.bak.*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "chokidar": "^4.0.3",
    "dotenv": "^17.3.1",
    "electron-store": "^11.0.2",
    "highlight.js": "^11.11.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "concurrently": "^9.2.1",
    "electron": "^40.2.1",
    "electron-builder": "^26.8.1",
    "electron-mock": "^0.5.0",
    "happy-dom": "^20.6.1",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.5"
  }
}
